        "renditionMap" : { },
        "type" : "region"
      }, {
        "components" : [ {
          "componentAttributes" : {
            "richTextValue" : "<h1><br></h1><h1><b>Welcome to the Department of Licensing {!CurrentUser.firstName}!</b></h1>"
          },
          "componentName" : "forceCommunity:richTextInline",
          "id" : "14a96265-ebde-4238-84fa-2925f2559bb8",
          "renderPriority" : "NEUTRAL",
          "renditionMap" : { },
          "type" : "component"
        }, {
          "componentAttributes" : {
            "richTextValue" : "<h2>Our Mission​</h2><p><span style=\"font-size: 18px;\">To build trust between our residents and their state government so everyone can trust the public services and the public servants who can make a difference in their everyday lives. </span><span style=\"font-size: 18px; color: rgb(0, 0, 0); background-color: rgba(255, 255, 255, 0.95);\">To earn the trust of residents every day by providing innovative regulatory solutions for our licensees and those they serve.</span></p><p><span style=\"font-size: 18px;\">﻿</span></p><h2>Our Vision</h2><p><span style=\"font-size: 18px;\">We envision a government without barriers where everyone has access to available tools to achieve economic success, and where our state resources are efficiently used&nbsp;and accountable to the public; T</span><span style=\"font-size: 18px; background-color: rgba(255, 255, 255, 0.95); color: rgb(0, 0, 0);\">o be the best at creating ‘next’ practices that deliver low-cost licensing and regulatory services and an exceptional customer experience. </span></p>"
          },
          "componentName" : "forceCommunity:richTextInline",
          "id" : "1479670e-381c-4f87-94ef-b9c45acc2f01",
          "renderPriority" : "NEUTRAL",
          "renditionMap" : { },
          "type" : "component"
        }, {
          "componentAttributes" : {
            "richTextValue" : "<h1><strong style=\"color: rgb(230, 0, 0); font-size: 18px;\"><img class=\"sfdcCbImage\" alt=\"\" src=\"{!contentAsset.AstroTrailheadXSmall.1}\">GPS SEs: START HERE</strong></h1>\n<p><strong>Before you demo:</strong></p>\n<ol>\n <li>Follow the <a href=\"https://salesforce.quip.com/ue5fAXAcoqb4#temp:C:TeM0a4638d7df7042d19dcf8981c\" rel=\"noopener noreferrer\" target=\"_blank\"><strong>Public Sector IDO Post Spin-Up Instructions</strong></a></li>\n <li><strong style=\"color: rgb(230, 0, 0);\">Important:</strong> Confirm that you have re-selected the \"LPI_Channel_Menu\" Deployment for the Channel Menu component, which near the footer at the very bottom of this page.</li>\n <li><span style=\"background-color: rgb(255, 255, 0);\">Remove this component</span><span style=\"background-color: rgb(255, 255, 0); color: rgb(0, 0, 0);\"> from the page layout</span></li>\n <li>Publish</li>\n <li><strong><em>Questions? </em></strong>Post in the #help-gps-ido slack channel!</li>\n</ol>\n<p>Replace this text with content of your own.</p>"
          },
          "componentName" : "forceCommunity:richTextInline",
          "id" : "d4424954-dc17-4dac-9a72-8295daa3ad4f",
          "renderPriority" : "NEUTRAL",
