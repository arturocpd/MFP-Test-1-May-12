          "componentAttributes" : {
            "richTextValue" : "<p style=\"text-align: center;\"><br></p>\n<p style=\"text-align: center;\"><br></p>\n<p style=\"text-align: center;\"><br></p>\n<p style=\"text-align: center;\"><img class=\"sfdcCbImage\" alt=\"\" src=\"{!contentAsset.LPI_Color_Stacked.1}\" style=\"width: 237.703px; height: 264.953px;\"></p>"
          },
