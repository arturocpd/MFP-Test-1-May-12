            "richTextValue" : "<p style=\"text-align: center;\"><br></p><h1 style=\"text-align: center;\"><strong style=\"font-size: 28px;\">Welcome to the Department of the Future {!CurrentUser.firstName}!</strong></h1><p style=\"text-align: center;\"><span style=\"font-size: 22px;\">Our site is a place where you can ask questions, seek assistance and collaborate with department staff </span></p><p style=\"text-align: center;\"><br></p><p>&nbsp;</p>"
